---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionShell from "../components/SectionShell.astro";
import Eyebrow from "../components/Eyebrow.astro";
import Button from "../components/Button.astro";
import HeroAccent from "../components/svg/HeroAccent.astro";
import FAQItem from "../components/FAQItem.astro";
import FinalCTA from "../components/sections/FinalCTA.astro";

const transitionsTile = {
  eyebrow: "Advisor Transitions",
  title: "Priced to your scope, not a seat count.",
  body: "Every firm's transition requirements and volume is different. We work with you to understand where FastTrackr can best support your transition, and to reflect scope and usage so you don't pay for anything you don't use.",
  ctaLabel: "Book an Exploratory Call",
  ctaHref: "/contact",
};

const moduleTiles = [
  {
    eyebrow: "Meeting Assistant",
    title: "Per-seat, free tier to start.",
    body: "For advisors and teams who want meeting prep, notes, and follow-ups handled. Start free, scale up as your team grows.",
  },
  {
    eyebrow: "Document Intelligence",
    title: "Per-seat, pay for what you use.",
    body: "For advisors and teams turning brokerage statements, tax docs, and equity comp into clean, structured data. Free tier to start.",
  },
  {
    eyebrow: "Client Onboarding",
    title: "Per-seat for advisors. Custom for firms.",
    body: "For advisors onboarding new clients faster, and firms running onboarding at volume. Pricing flexes to either.",
  },
];

const faqs = [
  {
    q: "Can we start with one module and add others?",
    a: "Yes. Most firms do.",
  },
  {
    q: "Do you offer enterprise contracts?",
    a: "Yes. For BDs, custodians, and large RIAs, we structure enterprise agreements tied to advisor and household volume.",
  },
  {
    q: "Is there a free trial?",
    a: "The Meeting Assistant and Document Intelligence modules have free tiers. Advisor Transitions starts with a paid pilot.",
  },
];
---

<BaseLayout
  title="Pricing, FastTrackr AI"
  description="Pricing built around the value you get. Value-based for transitions; per-seat for modules."
>
  <section class="relative overflow-hidden bg-bg-primary">
    <HeroAccent class="absolute -top-32 -right-40 w-[640px] h-[640px] hidden md:block" />
    <div class="container-site relative pt-20 md:pt-28 pb-16 md:pb-20">
      <div class="max-w-[820px]">
        <Eyebrow>Pricing</Eyebrow>
        <h1 class="mt-2 text-h1 text-text-primary">
          Pricing built around the value you get.
        </h1>
        <p class="mt-6 text-body-lg text-text-secondary max-w-[680px]">
          We don't sell seats by the dozen and hope you fit. Pricing flexes to
          what you're using FastTrackr for, and what it gives back to your firm.
        </p>
      </div>
    </div>
  </section>

  <SectionShell bg="secondary" ariaLabelledby="pricing-grid">
    <h2 id="pricing-grid" class="sr-only">Pricing across modules</h2>

    <div class="bg-bg-primary border border-border-subtle rounded-[12px] p-8 md:p-10 flex flex-col md:flex-row md:items-end md:justify-between gap-8">
      <div class="max-w-[760px]">
        <p class="text-eyebrow text-brand-green">{transitionsTile.eyebrow}</p>
        <h3 class="mt-3 text-h3 text-text-primary">{transitionsTile.title}</h3>
        <p class="mt-4 text-body text-text-secondary">{transitionsTile.body}</p>
      </div>
      <div class="shrink-0">
        <Button href={transitionsTile.ctaHref} variant="primary" size="sm">{transitionsTile.ctaLabel}</Button>
      </div>
    </div>

    <div class="mt-10">
      <p class="text-eyebrow text-brand-green">Other modules</p>
      <h3 class="mt-3 text-h3 text-text-primary max-w-[760px]">
        Industry-best pricing on every module. Talk to us separately.
      </h3>
    </div>

    <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-6">
      {
        moduleTiles.map((t) => (
          <div class="bg-bg-primary border border-border-subtle rounded-[12px] p-8 flex flex-col">
            <p class="text-eyebrow text-brand-green">{t.eyebrow}</p>
            <h4 class="mt-3 text-h4 text-text-primary">{t.title}</h4>
            <p class="mt-4 text-body text-text-secondary flex-1">{t.body}</p>
            <div class="mt-8">
              <Button href="/contact" variant="primary" size="sm">Talk to Us</Button>
            </div>
          </div>
        ))
      }
    </div>
  </SectionShell>

  <SectionShell bg="primary" density="md" containerClass="max-w-[820px] mx-auto" ariaLabelledby="pricing-faq">
    <div>
      <p class="text-eyebrow text-brand-green">FAQ</p>
      <h2 id="pricing-faq" class="mt-3 text-h2 text-text-primary">Pricing, answered.</h2>
    </div>
    <div class="mt-10">
      {faqs.map((f) => <FAQItem question={f.q}>{f.a}</FAQItem>)}
    </div>
  </SectionShell>

  <FinalCTA
    headline="Ready to talk pricing?"
    subhead="A 20-minute call to walk through what fits your firm."
  />
</BaseLayout>
