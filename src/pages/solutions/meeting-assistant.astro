---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionShell from "../../components/SectionShell.astro";
import Eyebrow from "../../components/Eyebrow.astro";
import Button from "../../components/Button.astro";
import HeroAccent from "../../components/svg/HeroAccent.astro";
import Icon from "../../components/svg/Icon.astro";
import TestimonialCard from "../../components/TestimonialCard.astro";
import FinalCTA from "../../components/sections/FinalCTA.astro";

const features = [
  "Generates pre-meeting prep from email and CRM data",
  "Summarizes in-person and virtual calls (Zoom, Teams, Google Meet)",
  "Drafts contextual follow-up emails and identifies action items",
  "Updates your CRM and other tools in one click",
];
---

<BaseLayout
  title="Meeting Assistant — FastTrackr AI"
  description="Pre-meeting prep, in-meeting notes, post-meeting follow-ups — handled. So you can focus on the conversation."
>
  <section class="relative overflow-hidden bg-bg-primary">
    <HeroAccent class="absolute -top-32 -right-40 w-[640px] h-[640px] hidden md:block" />
    <div class="container-site relative pt-20 md:pt-28 pb-16 md:pb-24">
      <div class="max-w-[860px]">
        <Eyebrow>Meeting Assistant</Eyebrow>
        <h1 class="mt-2 text-h1 text-text-primary">
          Your always-on meeting coordinator.
        </h1>
        <p class="mt-6 text-body-lg text-text-secondary max-w-[680px]">
          Pre-meeting prep, in-meeting notes, post-meeting follow-ups — handled.
          So you can focus on the conversation.
        </p>
        <div class="mt-10">
          <Button href="/contact" variant="primary">Book a Demo</Button>
        </div>
      </div>
    </div>
  </section>

  <SectionShell bg="secondary" ariaLabelledby="ma-features-heading">
    <div class="max-w-[820px]">
      <p class="text-eyebrow text-brand-green">What it does</p>
      <h2 id="ma-features-heading" class="mt-3 text-h2 text-text-primary">
        Built for the way advisors actually run client conversations.
      </h2>
    </div>
    <ul class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-4">
      {
        features.map((f) => (
          <li class="flex items-start gap-3 bg-bg-primary border border-border-subtle rounded-[12px] p-6">
            <span class="shrink-0 text-brand-green mt-0.5">
              <Icon name="check" size={20} strokeWidth={2.25} />
            </span>
            <span class="text-body text-text-primary">{f}</span>
          </li>
        ))
      }
    </ul>
  </SectionShell>

  <SectionShell bg="primary" density="md" ariaLabelledby="ma-why-heading">
    <div class="max-w-[820px]">
      <p class="text-eyebrow text-brand-green">Why advisors use it</p>
      <h2 id="ma-why-heading" class="mt-3 text-h2 text-text-primary">
        Top-performing advisors save 10–15 hours every week.
      </h2>
      <p class="mt-5 text-body-lg text-text-secondary">
        On meeting prep, note-taking, and follow-ups. The quality of meeting
        documentation goes up. Things stop slipping through the cracks. Clients
        notice.
      </p>
    </div>
  </SectionShell>

  <SectionShell bg="secondary" density="md" ariaLabelledby="ma-tm-heading">
    <h2 id="ma-tm-heading" class="sr-only">Testimonial</h2>
    <div class="max-w-[820px] mx-auto">
      <TestimonialCard
        variant="featured"
        quote="Using FastTrackr AI has been a key enhancement to my client meeting process. It's remarkably easy to use, the interface is intuitive, and the learning curve is minimal. Most importantly, the quality of the meeting notes is far better than what I would capture manually."
        name="Gregg D. Jensen"
        role="CCO and Head of Financial Planning"
        firm="Pathway Partners"
      />
    </div>
  </SectionShell>

  <FinalCTA />
</BaseLayout>
