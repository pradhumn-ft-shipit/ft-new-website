---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionShell from "../../components/SectionShell.astro";
import Eyebrow from "../../components/Eyebrow.astro";
import Button from "../../components/Button.astro";
import HeroAccent from "../../components/svg/HeroAccent.astro";
import Icon from "../../components/svg/Icon.astro";
import TestimonialCard from "../../components/TestimonialCard.astro";
import FinalCTA from "../../components/sections/FinalCTA.astro";

const features = [
  "Extracts data from brokerage, bank, tax, and equity compensation documents",
  "Organizes and summarizes information for analysis and reporting",
  "Enriches insights with current market data",
  "Exports to your tools — financial planning software, CRM, Excel",
];
---

<BaseLayout
  title="Document Intelligence — FastTrackr AI"
  description="From piles of client paperwork to instant insights. Brokerage, tax, equity comp, bank docs — extracted, organized, and ready in minutes."
>
  <section class="relative overflow-hidden bg-bg-primary">
    <HeroAccent class="absolute -top-32 -right-40 w-[640px] h-[640px] hidden md:block" />
    <div class="container-site relative pt-20 md:pt-28 pb-16 md:pb-24">
      <div class="max-w-[860px]">
        <Eyebrow>Document Intelligence</Eyebrow>
        <h1 class="mt-2 text-h1 text-text-primary">
          From piles of client paperwork to instant insights.
        </h1>
        <p class="mt-6 text-body-lg text-text-secondary max-w-[680px]">
          Brokerage statements, tax documents, equity comp, bank docs —
          extracted, organized, and ready for analysis in minutes.
        </p>
        <div class="mt-10">
          <Button href="/contact" variant="primary">Book a Demo</Button>
        </div>
      </div>
    </div>
  </section>

  <SectionShell bg="secondary" ariaLabelledby="di-features-heading">
    <div class="max-w-[820px]">
      <p class="text-eyebrow text-brand-green">What it does</p>
      <h2 id="di-features-heading" class="mt-3 text-h2 text-text-primary">
        Built for the documents wealth managers actually deal with.
      </h2>
    </div>
    <ul class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-4">
      {
        features.map((f) => (
          <li class="flex items-start gap-3 bg-bg-primary border border-border-subtle rounded-[12px] p-6">
            <span class="shrink-0 text-brand-green mt-0.5">
              <Icon name="check" size={20} strokeWidth={2.25} />
            </span>
            <span class="text-body text-text-primary">{f}</span>
          </li>
        ))
      }
    </ul>
  </SectionShell>

  <SectionShell bg="primary" density="md" ariaLabelledby="di-why-heading">
    <div class="max-w-[820px]">
      <p class="text-eyebrow text-brand-green">Why advisors use it</p>
      <h2 id="di-why-heading" class="mt-3 text-h2 text-text-primary">
        Hours of document review become minutes.
      </h2>
      <p class="mt-5 text-body-lg text-text-secondary">
        Document review used to be hours of manual work per client. Now it's
        minutes. The data lands clean, the summaries are usable, and the exports
        drop straight into the tools you already use.
      </p>
    </div>
  </SectionShell>

  <SectionShell bg="secondary" density="md" ariaLabelledby="di-tm-heading">
    <h2 id="di-tm-heading" class="sr-only">Testimonial</h2>
    <div class="max-w-[820px] mx-auto">
      <TestimonialCard
        variant="featured"
        quote="After evaluating multiple AI solutions for our practice, we chose FastTrackr for document processing. Its integrated platform has been invaluable. The time savings are impressive, and even more importantly, the quality of our financial planning and client deliverables has improved significantly."
        name="Sukesh Pai"
        role="Founder"
        firm="Trillium Square Advisors"
      />
    </div>
  </SectionShell>

  <FinalCTA />
</BaseLayout>
