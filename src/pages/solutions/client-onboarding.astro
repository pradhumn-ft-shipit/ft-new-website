---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionShell from "../../components/SectionShell.astro";
import Eyebrow from "../../components/Eyebrow.astro";
import Button from "../../components/Button.astro";
import HeroAccent from "../../components/svg/HeroAccent.astro";
import Icon from "../../components/svg/Icon.astro";
import FinalCTA from "../../components/sections/FinalCTA.astro";

const problems = [
  {
    title: "Days, sometimes weeks, between \"yes\" and \"fully onboarded.\"",
    body: "First impressions cool off in the gap.",
  },
  {
    title: "Multiple intake forms, scattered across tools.",
    body: "Clients fill out the same information three times across CRM, planning software, and account opening.",
  },
  {
    title: "Manual data entry into your stack.",
    body: "Someone keys it from email into the CRM. Then re-keys it into the planning software. Then re-keys it for the custodian.",
  },
  {
    title: "Errors live forever.",
    body: "A typo on day one becomes a wrong tax document at year-end.",
  },
];

const capabilities = [
  {
    title: "Data gathered from any source.",
    body: "Meetings, emails, prospect documents, extracted and structured automatically.",
  },
  {
    title: "Clients confirm, they don't retype.",
    body: "Send a clean, pre-filled summary for confirmation rather than another blank intake form.",
  },
  {
    title: "One source feeds your stack.",
    body: "CRM, planning software, account opening, populated in one motion.",
  },
  {
    title: "Account opening kicked off automatically.",
    body: "Disclosures, agreements, custodial paperwork, initiated in the same flow.",
  },
];

const outcomes = [
  "<strong>Days, not weeks</strong>, from yes to fully onboarded",
  "<strong>Cleaner data across your stack</strong>, entered once, used everywhere",
  "<strong>A first impression that matches the pitch</strong>, clients feel taken care of",
  "<strong>More capacity for new clients</strong>, onboarding stops being the bottleneck",
];
---

<BaseLayout
  title="Client Onboarding, FastTrackr AI"
  description="Onboard new clients in days, not weeks. The same engine built for advisor transitions, applied to your daily client onboarding."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-bg-primary">
    <HeroAccent class="absolute -top-32 -right-40 w-[640px] h-[640px] hidden md:block" />
    <div class="container-site relative pt-20 md:pt-28 pb-16 md:pb-24">
      <div class="max-w-[860px]">
        <Eyebrow>Client Onboarding</Eyebrow>
        <h1 class="mt-2 text-h1 text-text-primary">
          Onboard new clients in days, not weeks.
        </h1>
        <p class="mt-6 text-body-lg text-text-secondary max-w-[680px]">
          The same technology built to handle thousands of account openings
          during advisor transitions, now accelerating your day-to-day client
          onboarding.
        </p>
        <div class="mt-10">
          <Button href="/contact" variant="primary">Book a Demo</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem -->
  <SectionShell bg="secondary" ariaLabelledby="co-problem-heading">
    <div class="max-w-[820px]">
      <p class="text-eyebrow text-brand-green">The problem</p>
      <h2 id="co-problem-heading" class="mt-3 text-h2 text-text-primary">
        Bringing on a new client should be a celebration. Today, it's a slog.
      </h2>
    </div>

    <ul class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        problems.map((p) => (
          <li class="bg-bg-primary border border-border-subtle rounded-[12px] p-6 md:p-8">
            <h3 class="text-h4 text-text-primary">{p.title}</h3>
            <p class="mt-3 text-body text-text-secondary">{p.body}</p>
          </li>
        ))
      }
    </ul>
    <p class="mt-10 max-w-[820px] text-body-lg text-text-secondary">
      The new client experience starts here. And right now, it sets the wrong tone.
    </p>
  </SectionShell>

  <!-- How -->
  <SectionShell bg="primary" ariaLabelledby="co-how-heading">
    <div class="max-w-[820px]">
      <p class="text-eyebrow text-brand-green">How FastTrackr changes it</p>
      <h2 id="co-how-heading" class="mt-3 text-h2 text-text-primary">
        Same engine. Right-sized for the daily flow.
      </h2>
      <p class="mt-5 text-body-lg text-text-secondary">
        The same AI engine that handles thousands of account openings during
        advisor transitions now handles your individual client onboarding flow.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        capabilities.map((c) => (
          <div class="bg-bg-primary border border-border-subtle rounded-[12px] p-6 md:p-8">
            <div class="text-brand-green mb-4">
              <Icon name="check" size={24} strokeWidth={2} />
            </div>
            <h3 class="text-h4 text-text-primary">{c.title}</h3>
            <p class="mt-3 text-body text-text-secondary">{c.body}</p>
          </div>
        ))
      }
    </div>
  </SectionShell>

  <!-- Outcomes -->
  <SectionShell bg="secondary" ariaLabelledby="co-outcomes-heading">
    <div class="max-w-[820px]">
      <p class="text-eyebrow text-brand-green">Outcomes</p>
      <h2 id="co-outcomes-heading" class="sr-only">Outcomes</h2>
    </div>
    <ul class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
      {
        outcomes.map((o) => (
          <li class="flex items-start gap-3 bg-bg-primary border border-border-subtle rounded-[12px] p-5">
            <span class="shrink-0 text-brand-green mt-0.5">
              <Icon name="check" size={20} strokeWidth={2.25} />
            </span>
            <span class="text-body text-text-primary" set:html={o} />
          </li>
        ))
      }
    </ul>
  </SectionShell>

  <FinalCTA />
</BaseLayout>
