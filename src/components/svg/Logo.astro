---
/*
 * FastTrackr AI wordmark. Real brand asset (PNG) shipped from /public/brand
 * so it's served as a static file with long-cache headers (vercel.json
 * pins /_astro/* to immutable; the brand assets get default cache).
 *
 * `eager` + `fetchpriority="high"` so the header doesn't flash blank during
 * first paint. Explicit width/height prevents CLS.
 */
interface Props {
  class?: string;
  height?: number;
  variant?: "wordmark" | "mark";
  eager?: boolean;
}

const {
  class: className = "",
  height = 28,
  variant = "wordmark",
  eager = false,
} = Astro.props;

const intrinsic = variant === "wordmark" ? { w: 657, h: 141 } : { w: 150, h: 150 };
const renderedWidth = Math.round((height * intrinsic.w) / intrinsic.h);
const src = variant === "wordmark"
  ? "/brand/fasttrackr-wordmark.png"
  : "/brand/fasttrackr-mark.png";
---

<img
  src={src}
  alt="FastTrackr AI"
  width={renderedWidth}
  height={height}
  loading={eager ? "eager" : "lazy"}
  decoding="async"
  fetchpriority={eager ? "high" : "auto"}
  class={`block h-auto w-auto ${className}`}
  style={`height:${height}px`}
/>
