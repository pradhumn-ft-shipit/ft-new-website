---
/*
 * Flywheel loop, redo. Modern, animated, no kicker copy.
 *
 * Design notes:
 * - Pill nodes sit on a faint ring (the "wire"); a brand-green dashed overlay
 *   rotates clockwise via animated stroke-dashoffset to convey energy flow.
 * - The center carries a soft radial glow that breathes (scale + opacity loop).
 * - Nodes fade in with a small upward translation, staggered, on first paint.
 * - Mobile collapses to a vertical chain with the same flowing accent and a
 *   loop-back arc that reuses the same dash animation.
 *
 * Pure CSS animations (no SMIL) so the browser composites smoothly and
 * `prefers-reduced-motion` can disable them cleanly.
 *
 * Labels per guideline-copy/02-homepage.md §6:
 *   Faster transition → Better client experience → Retained AUM →
 *   No ops-team burnout → (loops)
 */

const labels = [
  "Faster transition",
  "Better client experience",
  "Retained AUM",
  "No ops-team burnout",
];

// Node positions (compass) at radius 180 from center (400, 240)
const nodes = [
  { x: 305, y: 34,  label: labels[0] },  // top
  { x: 485, y: 214, label: labels[1] },  // right
  { x: 305, y: 394, label: labels[2] },  // bottom
  { x: 125, y: 214, label: labels[3] },  // left
];

// Circle circumference for r=180 (used in dasharray math)
const C = Math.round(2 * Math.PI * 180); // ≈ 1131
---

<div class="flywheel">
  <!-- ── Desktop: ring with rotating flow ─────────────────── -->
  <svg
    class="hidden md:block w-full max-w-[760px] mx-auto"
    viewBox="0 0 800 500"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-labelledby="flywheel-title flywheel-desc"
  >
    <title id="flywheel-title">FastTrackr transition flywheel</title>
    <desc id="flywheel-desc">
      Faster transitions lead to a better client experience, which retains AUM,
      which keeps ops teams from burning out. The cycle compounds.
    </desc>

    <defs>
      <radialGradient id="fw-glow" cx="50%" cy="50%" r="50%">
        <stop offset="0%"  stop-color="var(--color-brand-green)" stop-opacity="0.22"/>
        <stop offset="55%" stop-color="var(--color-brand-green)" stop-opacity="0.05"/>
        <stop offset="100%" stop-color="var(--color-brand-green)" stop-opacity="0"/>
      </radialGradient>
      <filter id="fw-soft" x="-20%" y="-20%" width="140%" height="140%">
        <feDropShadow dx="0" dy="4" stdDeviation="6" flood-color="rgba(15,23,42,0.08)" />
      </filter>
    </defs>

    <!-- Center breathing glow -->
    <circle cx="400" cy="240" r="135" fill="url(#fw-glow)" class="fw-breathe" />

    <!-- Faint ring -->
    <circle
      cx="400" cy="240" r="180"
      fill="none"
      stroke="var(--color-border-subtle)"
      stroke-width="1.5"
    />

    <!-- Animated brand-green flow overlay -->
    <circle
      cx="400" cy="240" r="180"
      fill="none"
      stroke="var(--color-brand-green)"
      stroke-width="3"
      stroke-linecap="round"
      stroke-dasharray={`${Math.round(C * 0.18)} ${Math.round(C * 0.82)}`}
      class="fw-flow"
      transform="rotate(-90 400 240)"
    />

    <!-- Subtle dotted halo just inside the ring for depth -->
    <circle
      cx="400" cy="240" r="148"
      fill="none"
      stroke="var(--color-border-subtle)"
      stroke-width="1"
      stroke-dasharray="2 6"
      opacity="0.6"
    />

    <!-- Nodes -->
    <g>
      {nodes.map((n, i) => (
        <g class="fw-node" style={`animation-delay:${i * 120}ms`}>
          <rect
            x={n.x}
            y={n.y}
            width="190"
            height="52"
            rx="26"
            fill="var(--color-bg-primary)"
            stroke="var(--color-brand-green)"
            stroke-width="1.75"
            filter="url(#fw-soft)"
          />
          <text
            x={n.x + 95}
            y={n.y + 32}
            text-anchor="middle"
            font-family="var(--font-sans)"
            font-size="15"
            font-weight="600"
            fill="var(--color-text-primary)"
            letter-spacing="-0.005em"
          >{n.label}</text>
        </g>
      ))}
    </g>
  </svg>

  <!-- ── Mobile: vertical chain with the same flow accent ── -->
  <svg
    class="md:hidden w-full max-w-[340px] mx-auto"
    viewBox="0 0 340 580"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label="FastTrackr transition flywheel"
  >
    <defs>
      <radialGradient id="fw-glow-m" cx="50%" cy="50%" r="50%">
        <stop offset="0%"  stop-color="var(--color-brand-green)" stop-opacity="0.18"/>
        <stop offset="100%" stop-color="var(--color-brand-green)" stop-opacity="0"/>
      </radialGradient>
      <filter id="fw-soft-m" x="-20%" y="-20%" width="140%" height="140%">
        <feDropShadow dx="0" dy="3" stdDeviation="4" flood-color="rgba(15,23,42,0.08)" />
      </filter>
    </defs>

    <!-- Soft center glow column -->
    <ellipse cx="120" cy="290" rx="100" ry="220" fill="url(#fw-glow-m)" class="fw-breathe" />

    <!-- Vertical spine (faint) + a curved loop-back on the right -->
    <path
      d="M120 60 V520 C 220 520, 220 60, 120 60 Z"
      fill="none"
      stroke="var(--color-border-subtle)"
      stroke-width="1.25"
    />

    <!-- Flowing brand-green overlay using same path -->
    <path
      d="M120 60 V520 C 220 520, 220 60, 120 60"
      fill="none"
      stroke="var(--color-brand-green)"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-dasharray="180 1100"
      class="fw-flow-m"
    />

    <!-- 4 stacked pill nodes -->
    {labels.map((label, i) => (
      <g class="fw-node" style={`animation-delay:${i * 120}ms`}>
        <rect
          x="20" y={i * 130 + 36}
          width="200" height="56" rx="28"
          fill="var(--color-bg-primary)"
          stroke="var(--color-brand-green)"
          stroke-width="1.75"
          filter="url(#fw-soft-m)"
        />
        <text
          x="120" y={i * 130 + 70}
          text-anchor="middle"
          font-family="var(--font-sans)"
          font-size="14"
          font-weight="600"
          fill="var(--color-text-primary)"
        >{label}</text>
      </g>
    ))}
  </svg>
</div>

<style>
  .fw-flow {
    animation: fw-rotate 14s linear infinite;
    transform-box: fill-box;
    transform-origin: center;
  }
  .fw-flow-m {
    stroke-dashoffset: 0;
    animation: fw-flow-mobile 14s linear infinite;
  }
  .fw-breathe {
    transform-box: fill-box;
    transform-origin: center;
    animation: fw-breathe 5s ease-in-out infinite;
  }
  .fw-node {
    opacity: 0;
    transform: translateY(8px);
    animation: fw-enter 600ms ease-out forwards;
  }

  @keyframes fw-rotate {
    from { stroke-dashoffset: 0; }
    /* full circumference to walk one cycle */
    to   { stroke-dashoffset: -1131; }
  }
  @keyframes fw-flow-mobile {
    from { stroke-dashoffset: 0; }
    to   { stroke-dashoffset: -1280; }
  }
  @keyframes fw-breathe {
    0%, 100% { transform: scale(1); opacity: 0.85; }
    50%      { transform: scale(1.06); opacity: 1; }
  }
  @keyframes fw-enter {
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .fw-flow, .fw-flow-m, .fw-breathe, .fw-node {
      animation: none;
    }
    .fw-node {
      opacity: 1;
      transform: none;
    }
  }
</style>
