---
/*
 * Monoline icon library per 06-visuals §1.6: 1.75–2px stroke, 24px standard,
 * 32–40px for feature blocks. All inline SVG, all currentColor.
 *
 * Pick via the `name` prop. Add new icons here rather than scattering files.
 *
 * Naming follows Lucide/Phosphor conventions where there's a clear analog.
 */
type IconName =
  // ICP
  | "handshake"
  | "arrow-out"
  | "merge"
  | "shield-building"
  | "vault"
  // Capabilities (§4)
  | "clipboard"
  | "document"
  | "kanban"
  // Beyond Transitions (§8)
  | "mic"
  | "extract"
  // Misc
  | "check"
  | "arrow-right"
  | "users"
  | "spark";

interface Props {
  name: IconName;
  size?: number;
  strokeWidth?: number;
  class?: string;
}

const { name, size = 24, strokeWidth = 1.75, class: className = "" } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  {/* ── ICP icons ────────────────────────────────────────── */}
  {name === "handshake" && (
    <>
      <path d="M3 11.5 L6 8.5 L9 11 L12 14 L15 11 L17 13 M21 11.5 L18 8.5 L15 11" />
      <path d="M3 11.5 L7 15.5 M21 11.5 L17 15.5" />
      <path d="M9 11 L11 9 M14 8.5 L11 5.5 L8 7" opacity="0.5" />
    </>
  )}
  {name === "arrow-out" && (
    <>
      <path d="M14 4 H20 V10" />
      <path d="M20 4 L11 13" />
      <path d="M19 14 V19 A1 1 0 0 1 18 20 H5 A1 1 0 0 1 4 19 V6 A1 1 0 0 1 5 5 H10" />
    </>
  )}
  {name === "merge" && (
    <>
      <circle cx="6" cy="6" r="2.5" />
      <circle cx="18" cy="6" r="2.5" />
      <circle cx="12" cy="18" r="2.5" />
      <path d="M7.5 7.5 L11 15.5 M16.5 7.5 L13 15.5" />
    </>
  )}
  {name === "shield-building" && (
    <>
      <path d="M12 3 L19 6 V12 C19 16.5 15.5 19.5 12 21 C8.5 19.5 5 16.5 5 12 V6 Z" />
      <path d="M9 14 V10 H15 V14 M9 11 H15 M11 14 V18 M13 14 V18" />
    </>
  )}
  {name === "vault" && (
    <>
      <rect x="3" y="5" width="18" height="14" rx="2" />
      <circle cx="12" cy="12" r="3.5" />
      <path d="M12 8.5 V10 M14.5 12 H16 M9.5 12 H8 M12 14 V15.5" />
      <path d="M5 19 V21 M19 19 V21" />
    </>
  )}

  {/* ── Capabilities (§4) ────────────────────────────────── */}
  {name === "clipboard" && (
    <>
      <rect x="6" y="4" width="12" height="17" rx="2" />
      <rect x="9" y="2.5" width="6" height="3.5" rx="1" />
      <path d="M9 11 H15 M9 14 H15 M9 17 H13" />
    </>
  )}
  {name === "document" && (
    <>
      <path d="M14 3 H7 A2 2 0 0 0 5 5 V19 A2 2 0 0 0 7 21 H17 A2 2 0 0 0 19 19 V8 Z" />
      <path d="M14 3 V8 H19" />
      <path d="M9 13 H15 M9 16 H13" />
    </>
  )}
  {name === "kanban" && (
    <>
      <rect x="3" y="3" width="18" height="18" rx="2" />
      <path d="M9 7 V14 M15 7 V11 M3 17 H21" />
    </>
  )}

  {/* ── Beyond (§8) ──────────────────────────────────────── */}
  {name === "mic" && (
    <>
      <rect x="9" y="3" width="6" height="11" rx="3" />
      <path d="M5 11 V12 A7 7 0 0 0 19 12 V11 M12 19 V22 M9 22 H15" />
    </>
  )}
  {name === "extract" && (
    <>
      <rect x="3" y="4" width="10" height="14" rx="1.5" />
      <path d="M6 8 H10 M6 11 H10 M6 14 H8" />
      <path d="M14 12 H21 M18 9 L21 12 L18 15" />
    </>
  )}

  {/* ── Misc ─────────────────────────────────────────────── */}
  {name === "check" && <path d="M5 12 L10 17 L19 7" />}
  {name === "arrow-right" && <path d="M5 12 H19 M13 6 L19 12 L13 18" />}
  {name === "users" && (
    <>
      <circle cx="9" cy="8" r="3.5" />
      <circle cx="17" cy="9" r="2.5" />
      <path d="M3 19 C3 16 5.5 14 9 14 C12.5 14 15 16 15 19" />
      <path d="M15 14 C18 14 21 15.5 21 18" />
    </>
  )}
  {name === "spark" && (
    <>
      <path d="M12 3 V8 M12 16 V21 M3 12 H8 M16 12 H21" />
      <path d="M6 6 L9 9 M15 15 L18 18 M6 18 L9 15 M15 9 L18 6" />
    </>
  )}
</svg>
