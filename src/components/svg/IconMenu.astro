---
interface Props {
  class?: string;
  size?: number;
}
const { class: className = "", size = 24 } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  class={className}
  aria-hidden="true"
>
  <path d="M4 7 H20 M4 12 H20 M4 17 H20" />
</svg>
