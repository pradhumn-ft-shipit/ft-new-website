---
import Logo from "./svg/Logo.astro";
import SocialIcons from "./svg/SocialIcons.astro";

const cols = [
  {
    heading: "Solutions",
    links: [
      { label: "Advisor Transitions", href: "/solutions/advisor-transitions" },
      { label: "Client Onboarding", href: "/solutions/client-onboarding" },
      { label: "Meeting Assistant", href: "/solutions/meeting-assistant" },
      { label: "Document Intelligence", href: "/solutions/document-intelligence" },
    ],
  },
  {
    heading: "Who We Serve",
    links: [
      { label: "Transition Consultants", href: "/who-we-serve/transition-consultants" },
      { label: "Breakaway Advisors", href: "/who-we-serve/breakaway-advisors" },
      { label: "Acquisitive RIAs", href: "/who-we-serve/acquisitive-rias" },
      { label: "Independent Broker-Dealers", href: "/who-we-serve/independent-broker-dealers" },
      { label: "Custodians", href: "/who-we-serve/custodians" },
    ],
  },
  {
    heading: "Resources",
    links: [
      { label: "Blog", href: "/blog" },
      { label: "Advisor Ally Podcast", href: "/podcast" },
    ],
  },
  {
    heading: "Company",
    links: [
      { label: "About", href: "/about" },
      { label: "Pricing", href: "/pricing" },
      { label: "Contact", href: "/contact" },
      { label: "Book a Demo", href: "/contact" },
    ],
  },
];

const socials = [
  { name: "linkedin" as const, href: "https://www.linkedin.com/company/fasttrackrai" },
  { name: "youtube" as const, href: "https://www.youtube.com/@fasttrackrai" },
  { name: "x" as const, href: "https://x.com/fasttrackrai" },
  { name: "facebook" as const, href: "https://facebook.com/fasttrackrai" },
  { name: "instagram" as const, href: "https://instagram.com/fasttrackrai" },
];
---

<footer class="bg-bg-secondary mt-16">
  <div class="container-site pt-20 pb-8">
    <!-- Top grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-10">
      <!-- Brand block -->
      <div class="col-span-2 md:col-span-3 lg:col-span-1">
        <a href="/" class="inline-flex items-center" aria-label="FastTrackr AI, Home">
          <Logo height={26} />
        </a>
        <p class="mt-4 max-w-[240px] text-body-sm text-text-secondary">
          Reimagining wealth management. One complex workflow at a time.
        </p>
      </div>

      <!-- Nav columns -->
      {
        cols.map((col) => (
          <div>
            <h4 class="text-[13px] font-semibold uppercase tracking-[0.08em] text-text-primary">
              {col.heading}
            </h4>
            <ul class="mt-4 space-y-3">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-body-sm text-text-secondary hover:text-text-primary"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- Podcast block -->
    <div class="mt-16 mb-16">
      <div class="rounded-[12px] border border-border-subtle bg-bg-primary p-8 max-w-3xl mx-auto">
        <h4 class="text-h4 text-text-primary">Advisor Ally Podcast</h4>
        <p class="mt-2 text-body-sm text-text-secondary">
          Tune in to our podcast on advisor transitions, technology, and the future of wealth management.
        </p>
        <div class="mt-4 flex flex-wrap gap-3">
          <a
            href="https://www.youtube.com/@fasttrackrai"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-md border border-border-subtle text-body-sm text-text-primary hover:bg-bg-secondary"
          >YouTube</a>
          <a
            href="https://podcasts.apple.com/"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-md border border-border-subtle text-body-sm text-text-primary hover:bg-bg-secondary"
          >Apple Podcasts</a>
          <a
            href="https://open.spotify.com/"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-md border border-border-subtle text-body-sm text-text-primary hover:bg-bg-secondary"
          >Spotify</a>
        </div>
      </div>
    </div>

    <!-- Bottom strip -->
    <div class="pt-6 border-t border-border-subtle flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-6">
      <div class="flex items-center gap-4 text-text-muted">
        {
          socials.map((s) => (
            <a
              href={s.href}
              class="hover:text-text-primary"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.name}
            >
              <SocialIcons name={s.name} size={20} />
            </a>
          ))
        }
      </div>

      <div class="text-body-sm text-text-muted">
        <a href="/privacy-policy" class="hover:text-text-primary">Privacy Policy</a>
        <span aria-hidden="true"> · </span>
        <a href="/tos" class="hover:text-text-primary">Terms of Service</a>
      </div>

      <div class="text-body-sm text-text-muted text-right">
        © 2026 FastTrackr Inc. All rights reserved.
        <span class="block text-[12px]">Backed by gAI Ventures</span>
      </div>
    </div>
  </div>
</footer>
