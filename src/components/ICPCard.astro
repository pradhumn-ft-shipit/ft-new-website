---
/*
 * ICP card per 06-visuals §7: 32px-line icon top, H3 audience name,
 * body description, "Learn more →" tertiary link. Entire card clickable.
 */
interface Props {
  href: string;
  title: string;
  description: string;
  cta?: string;
  class?: string;
}

const { href, title, description, cta = "Learn more", class: className = "" } = Astro.props;
---

<a
  href={href}
  class={`group flex flex-col bg-bg-primary border border-border-subtle rounded-[12px] p-6 md:p-8 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_4px_16px_rgba(15,23,42,0.06)] ${className}`}
>
  <div class="text-text-primary">
    <slot name="icon" />
  </div>
  <h3 class="mt-6 text-h3 text-text-primary">{title}</h3>
  <p class="mt-3 text-body text-text-secondary">{description}</p>
  <span
    class="mt-6 inline-flex items-center gap-1 text-[15px] font-medium text-text-primary group-hover:text-brand-green"
  >
    {cta}
    <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
  </span>
</a>
