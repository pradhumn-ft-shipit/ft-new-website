---
import SectionShell from "../SectionShell.astro";
import ICPCard from "../ICPCard.astro";
import Icon from "../svg/Icon.astro";

const cards = [
  {
    icon: "handshake" as const,
    title: "Transition Consultants",
    href: "/who-we-serve/transition-consultants",
    description:
      "Take on more deals without taking on more admin slog. Your team moves more books with the same headcount.",
  },
  {
    icon: "arrow-out" as const,
    title: "Breakaway Advisors",
    href: "/who-we-serve/breakaway-advisors",
    description:
      "Bring your book to your new firm without burning out your team or losing your clients.",
  },
  {
    icon: "merge" as const,
    title: "Acquisitive RIAs",
    href: "/who-we-serve/acquisitive-rias",
    description:
      "Protect AUM and accelerate revenue through every M&A integration. Cut weeks out of every deal.",
  },
  {
    icon: "shield-building" as const,
    title: "Independent Broker-Dealers",
    href: "/who-we-serve/independent-broker-dealers",
    description:
      "Win advisor recruits with a transition experience that actually works. Stop losing recruits to the firm with the smoother onboarding.",
  },
  {
    icon: "vault" as const,
    title: "Custodians",
    href: "/who-we-serve/custodians",
    description:
      "Help your advisors grow faster, acquire better, and onboard onto your platform smoothly. Be the on-ramp for every new RIA and advisory practice.",
  },
];
---

<SectionShell bg="primary" ariaLabelledby="icp-heading">
  <div class="text-center max-w-[820px] mx-auto">
    <p class="text-eyebrow text-brand-green">Built for every player</p>
    <h2 id="icp-heading" class="mt-3 text-h2 text-text-primary">
      Built for every player in the transition.
    </h2>
    <p class="mt-5 text-body-lg text-text-secondary">
      Click through to see what changes for you.
    </p>
  </div>

  <!--
    Desktop: 3-on-top, 2-centered-below.
    Use a 6-col grid; first three cards span 2 each, last two span 2 each
    starting at col 2 and col 4 to center the orphan row.
  -->
  <div class="mt-14 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-6">
    {
      cards.map((c, i) => {
        const positions = [
          "lg:col-span-2 lg:col-start-1",
          "lg:col-span-2 lg:col-start-3",
          "lg:col-span-2 lg:col-start-5",
          "lg:col-span-2 lg:col-start-2",
          "lg:col-span-2 lg:col-start-4",
        ];
        return (
          <ICPCard
            href={c.href}
            title={c.title}
            description={c.description}
            class={positions[i]}
          >
            <Icon slot="icon" name={c.icon} size={32} />
          </ICPCard>
        );
      })
    }
  </div>
</SectionShell>
