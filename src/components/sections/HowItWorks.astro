---
import SectionShell from "../SectionShell.astro";
import ImagePlaceholder from "../ImagePlaceholder.astro";

const steps = [
  {
    n: "01",
    title: "We learn your book",
    body: "Where you're coming from. Where you're going. Every household, every account, every quirk. Mapped before day one, so nothing surprises you mid-move.",
    visual: { label: "Book Mapping UI", detail: "Custodian, household, and account graph with edge-case flags." },
  },
  {
    n: "02",
    title: "AI-driven data collection",
    body: "What used to take days happens in minutes. Clients confirm what we already have, they don't fill out manual forms again. The intake disappears, the experience improves.",
    visual: { label: "Client Confirmation Flow", detail: "Pre-filled household summary with one-tap confirm." },
  },
  {
    n: "03",
    title: "Custodian forms, auto-filled",
    body: "Push directly to your custodian via API where supported. Or get pre-filled forms ready for client signature. Either way: no retyping, no copy-paste between tabs.",
    visual: { label: "Auto-filled Form View", detail: "Side-by-side: source data and the rendered custodian form." },
  },
  {
    n: "04",
    title: "Visibility, end to end",
    body: "From day one to the final asset transfer. Every household, every step, visible to you, your team, and your clients. No more blind handoffs. No more \"where are we on this one?\"",
    visual: { label: "Transition Dashboard", detail: "Status by household, NIGO alerts, projected go-live." },
  },
];
---

<SectionShell bg="primary" id="how-it-works" ariaLabelledby="hiw-heading">
  <div class="text-center max-w-[820px] mx-auto">
    <p class="text-eyebrow text-brand-green">How it works</p>
    <h2 id="hiw-heading" class="mt-3 text-h2 text-text-primary">
      Every transition is different. We've built for that.
    </h2>
    <p class="mt-5 text-body-lg text-text-secondary">
      No two books move the same way. The process flexes around your specifics
     , your book, your custodians, your edge cases.
    </p>
  </div>

  <ol class="relative mt-20 space-y-16 md:space-y-24">
    <!-- Vertical dotted connector, left side -->
    <span
      aria-hidden="true"
      class="hidden md:block pointer-events-none absolute left-[18px] top-2 bottom-12 w-px bg-[radial-gradient(circle,var(--color-border-strong)_1px,transparent_1.5px)] [background-size:1px_8px] [background-repeat:repeat-y]"
    ></span>

    {
      steps.map((s, i) => {
        const textFirst = i % 2 === 0;
        const textOrder = textFirst ? "md:order-1" : "md:order-2";
        const visualOrder = textFirst ? "md:order-2" : "md:order-1";
        return (
          <li class="relative grid md:grid-cols-2 gap-8 md:gap-16 items-start">
            <div class={`relative md:pl-16 ${textOrder}`}>
              <span
                class="absolute left-0 top-0 hidden md:flex items-center justify-center w-9 h-9 rounded-full bg-bg-primary border border-brand-green text-[12px] font-semibold text-brand-green"
                aria-hidden="true"
              >{s.n}</span>
              <p class="text-eyebrow text-brand-green md:hidden">Step {s.n}</p>
              <h3 class="mt-2 md:mt-0 text-h3 text-text-primary">{s.title}</h3>
              <p class="mt-4 text-body text-text-secondary">{s.body}</p>
            </div>

            <div class={visualOrder}>
              <ImagePlaceholder
                label={s.visual.label}
                detail={s.visual.detail}
                tone={i % 2 === 0 ? "tint" : "secondary"}
                aspect="video"
                class="max-w-[540px]"
              />
            </div>
          </li>
        );
      })
    }
  </ol>
</SectionShell>
