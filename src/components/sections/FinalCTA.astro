---
import Button from "../Button.astro";

interface Props {
  headline?: string;
  subhead?: string;
}

const {
  headline = "Let's reimagine how your next transition feels.",
  subhead = "A 20-minute walkthrough is enough to show you whether this works for your book.",
} = Astro.props;
---

<section class="bg-bg-tint">
  <div class="container-site section-y text-center max-w-[900px] mx-auto">
    <h2 class="text-h2 text-text-primary">{headline}</h2>
    <p class="mt-4 text-body-lg text-text-secondary">{subhead}</p>
    <div class="mt-10 flex flex-col items-center gap-3">
      <Button href="/contact" variant="primary" size="lg">Book a Demo</Button>
      <p class="text-body-sm text-text-secondary">
        Prefer to write first?
        <a class="underline hover:text-text-primary" href="/contact">Send us a note</a>.
      </p>
    </div>
  </div>
</section>
