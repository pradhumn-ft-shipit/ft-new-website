---
import SectionShell from "../SectionShell.astro";
import Icon from "../svg/Icon.astro";

const blocks = [
  {
    icon: "clipboard" as const,
    title: "Data Collection",
    body: "AI extracts client and account data from existing sources of information (systems, docs, conversations). Pre-populated household records, ready for review, without another long blank intake form.",
  },
  {
    icon: "document" as const,
    title: "Documentation",
    body: "Smart mapping across end custodians and firms. The right documents identified, pre-filled, and ready for signature. Push to the custodian via API where supported, or generate signature-ready documents.",
  },
  {
    icon: "kanban" as const,
    title: "Project Management",
    body: "Hundreds of households, tracked and proactively managed in one place. Replaces the Excel war room. Visible to you, your team, and your clients.",
  },
];
---

<SectionShell bg="secondary" ariaLabelledby="solution-heading">
  <div class="text-center max-w-[820px] mx-auto">
    <p class="text-eyebrow text-brand-green">What we built</p>
    <h2 id="solution-heading" class="mt-3 text-h2 text-text-primary">
      Built for transition. Not retrofitted with it.
    </h2>
    <p class="mt-5 text-body-lg text-text-secondary max-w-[760px] mx-auto">
      FastTrackr is shaped by advisory practices, transition consultants, and
      operators who've moved billions in client assets. We've encoded what they
      know and their best practices into a system that handles the work, the
      quirks, and the edge cases that others miss.
    </p>
    <p class="mt-6 text-body-lg font-semibold text-text-primary max-w-[760px] mx-auto">
      Every transition is different. We get that. The system flexes around
      your book, not the other way around.
    </p>
  </div>

  <div class="mt-16 grid grid-cols-1 md:grid-cols-3 md:divide-x md:divide-border-subtle">
    {
      blocks.map((b) => (
        <div class="px-0 md:px-8 first:md:pl-0 last:md:pr-0 py-6 md:py-0">
          <div class="text-brand-green">
            <Icon name={b.icon} size={32} strokeWidth={1.75} />
          </div>
          <h3 class="mt-4 text-h3 text-text-primary">{b.title}</h3>
          <p class="mt-3 text-body text-text-secondary">{b.body}</p>
        </div>
      ))
    }
  </div>
</SectionShell>
