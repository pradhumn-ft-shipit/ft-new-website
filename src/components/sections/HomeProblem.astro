---
import SectionShell from "../SectionShell.astro";

/*
 * §3 Pain cards. Each card carries a custom inline SVG visual specific to
 * its theme, instead of a generic dot accent. Visuals stay monoline + brand
 * tones (text-muted base, brand-green accent) so the grid reads cohesive.
 */

const pains = [
  {
    title: "90 days. Sometimes longer.",
    body: "Months of repapering before the last asset transfers. Revenue paused. Client relationships in limbo.",
    visual: "calendar",
  },
  {
    title: "Hundreds of forms. Per book.",
    body: "Account applications, transfer-of-asset forms, services and firm paperwork, multiplied by every household.",
    visual: "papers",
  },
  {
    title: "Tracked in spreadsheets.",
    body: "Hundreds of accounts. Ops teams chasing status and inputs across emails, PDFs, and calls. One mis-keyed cell and the picture changes.",
    visual: "grid",
  },
  {
    title: "Burned-out teams.",
    body: "Transition season is overtime season. Mistakes pile up. So does the resentment.",
    visual: "battery",
  },
  {
    title: "NIGO means rework.",
    body: "Even one missing field can lead to a rejection. Multiply that by hundreds.",
    visual: "loop",
  },
  {
    title: "Anxious clients.",
    body: "They notice when the move feels disorganized. Some quietly walk.",
    visual: "wait",
  },
] as const;
---

<SectionShell bg="primary" id="the-problem" ariaLabelledby="problem-heading">
  <div class="text-center max-w-[820px] mx-auto">
    <p class="text-eyebrow text-brand-green">What's broken</p>
    <h2 id="problem-heading" class="mt-3 text-h2 text-text-primary">
      If you've moved a book before, you know.
    </h2>
    <p class="mt-5 text-body-lg text-text-secondary">
      Repapering hasn't changed in decades. Advisors and their teams just learned
      to live with it. The process is broken, and clients, advisors, and teams
      all suffer for it.
    </p>
  </div>

  <ul class="mt-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {
      pains.map((p) => (
        <li class="group/pain relative bg-bg-primary border border-border-subtle rounded-[12px] p-6 md:p-8 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_4px_16px_rgba(15,23,42,0.06)] overflow-hidden">
          <div class="pain-visual" aria-hidden="true" data-visual={p.visual}>
            {p.visual === "calendar" && (
              <svg viewBox="0 0 80 64" fill="none" xmlns="http://www.w3.org/2000/svg" class="block w-20 h-16">
                <rect x="4" y="10" width="44" height="44" rx="6" stroke="currentColor" stroke-width="1.75" />
                <path d="M4 22 H48" stroke="currentColor" stroke-width="1.75" />
                <path d="M16 6 V14 M36 6 V14" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
                <rect x="11" y="28" width="6" height="6" rx="1" fill="currentColor" opacity="0.35" />
                <rect x="21" y="28" width="6" height="6" rx="1" fill="currentColor" opacity="0.2" />
                <rect x="31" y="28" width="6" height="6" rx="1" class="text-brand-green" fill="currentColor" />
                <rect x="11" y="40" width="6" height="6" rx="1" fill="currentColor" opacity="0.2" />
                <rect x="21" y="40" width="6" height="6" rx="1" fill="currentColor" opacity="0.2" />
                <path d="M52 32 H72 M66 26 L72 32 L66 38" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            )}
            {p.visual === "papers" && (
              <svg viewBox="0 0 80 64" fill="none" xmlns="http://www.w3.org/2000/svg" class="block w-20 h-16">
                <rect x="6" y="6" width="38" height="50" rx="3" stroke="currentColor" stroke-width="1.5" opacity="0.4" />
                <rect x="14" y="12" width="38" height="50" rx="3" stroke="currentColor" stroke-width="1.5" opacity="0.6" />
                <rect x="22" y="18" width="38" height="44" rx="3" stroke="currentColor" stroke-width="1.75" fill="var(--color-bg-primary)" />
                <path d="M28 28 H52 M28 34 H48 M28 40 H42" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                <circle cx="62" cy="22" r="8" class="text-brand-green" stroke="currentColor" stroke-width="1.75" fill="var(--color-bg-primary)" />
                <path d="M59 22 L61 24 L65 19" class="text-brand-green" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            )}
            {p.visual === "grid" && (
              <svg viewBox="0 0 80 64" fill="none" xmlns="http://www.w3.org/2000/svg" class="block w-20 h-16">
                <rect x="4" y="8" width="72" height="48" rx="4" stroke="currentColor" stroke-width="1.75" />
                <path d="M4 22 H76 M4 36 H76 M4 50 H76 M22 8 V56 M40 8 V56 M58 8 V56" stroke="currentColor" stroke-width="1" opacity="0.5" />
                <rect x="22" y="22" width="18" height="14" class="text-brand-green" fill="currentColor" opacity="0.18" />
                <path d="M24 26 L38 34 M38 26 L24 34" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-brand-green" />
              </svg>
            )}
            {p.visual === "battery" && (
              <svg viewBox="0 0 80 64" fill="none" xmlns="http://www.w3.org/2000/svg" class="block w-20 h-16">
                <rect x="6" y="20" width="60" height="24" rx="4" stroke="currentColor" stroke-width="1.75" />
                <rect x="66" y="26" width="6" height="12" rx="1.5" stroke="currentColor" stroke-width="1.75" />
                <rect x="10" y="24" width="10" height="16" rx="1.5" class="text-brand-green" fill="currentColor" opacity="0.7" />
                <path d="M40 12 Q42 16, 38 18 Q34 22, 40 26" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.55" />
                <path d="M52 8 Q54 12, 50 14 Q46 18, 52 22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.4" />
              </svg>
            )}
            {p.visual === "loop" && (
              <svg viewBox="0 0 80 64" fill="none" xmlns="http://www.w3.org/2000/svg" class="block w-20 h-16">
                <path d="M14 32 A18 18 0 1 1 32 50" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
                <path d="M28 46 L33 51 L26 54" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" fill="none" />
                <rect x="44" y="20" width="28" height="24" rx="3" stroke="currentColor" stroke-width="1.75" />
                <path d="M50 28 L66 28 M50 34 L60 34" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                <circle cx="64" cy="44" r="9" class="text-brand-green" fill="var(--color-bg-primary)" stroke="currentColor" stroke-width="1.75" />
                <path d="M60 40 L68 48 M68 40 L60 48" class="text-brand-green" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
              </svg>
            )}
            {p.visual === "wait" && (
              <svg viewBox="0 0 80 64" fill="none" xmlns="http://www.w3.org/2000/svg" class="block w-20 h-16">
                <path d="M14 16 H50 A6 6 0 0 1 56 22 V36 A6 6 0 0 1 50 42 H30 L20 50 V42 H14 A6 6 0 0 1 8 36 V22 A6 6 0 0 1 14 16 Z" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round" />
                <circle cx="22" cy="29" r="2" fill="currentColor" />
                <circle cx="32" cy="29" r="2" fill="currentColor" />
                <circle cx="42" cy="29" r="2" fill="currentColor" />
                <circle cx="64" cy="44" r="9" class="text-brand-green" fill="var(--color-bg-primary)" stroke="currentColor" stroke-width="1.75" />
                <path d="M64 39 V45 L67 47" class="text-brand-green" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            )}
          </div>
          <h3 class="mt-6 text-h3 text-text-primary">{p.title}</h3>
          <p class="mt-3 text-body text-text-secondary">{p.body}</p>
        </li>
      ))
    }
  </ul>
</SectionShell>

<style>
  .pain-visual {
    color: var(--color-text-muted);
    transition: color 200ms ease, transform 300ms ease;
  }
  .group\/pain:hover .pain-visual {
    color: var(--color-text-primary);
    transform: translateY(-1px);
  }
  .pain-visual .text-brand-green {
    color: var(--color-brand-green);
  }
</style>
