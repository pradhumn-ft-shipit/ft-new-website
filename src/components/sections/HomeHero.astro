---
import Button from "../Button.astro";
import HeroAccent from "../svg/HeroAccent.astro";
---

<section class="relative overflow-hidden bg-bg-primary">
  <!-- Decorative accent, upper right -->
  <HeroAccent class="absolute -top-32 -right-40 w-[640px] h-[640px] hidden md:block" />

  <div class="container-site relative pt-24 md:pt-32 pb-20 md:pb-32">
    <div class="max-w-[860px]">
      <h1 class="text-display text-text-primary">
        Advisor transitions, finally built right.
      </h1>
      <p class="mt-6 text-body-lg text-text-secondary max-w-[640px]">
        Purpose-built AI for advisor transitions, shaped by consultants, operators,
        and RIA founders who move billions in client assets every year.
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-4 md:gap-6">
        <Button href="/contact" variant="primary">Book a Demo</Button>
        <a
          href="#how-it-works"
          class="inline-flex items-center gap-1 text-[15px] font-medium text-text-primary hover:underline underline-offset-4"
        >
          See how it works <span aria-hidden="true">↓</span>
        </a>
      </div>
    </div>
  </div>
</section>
