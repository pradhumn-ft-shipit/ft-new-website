---
import SectionShell from "../SectionShell.astro";
import Icon from "../svg/Icon.astro";

const cards = [
  {
    icon: "users" as const,
    title: "Client Onboarding",
    href: "/solutions/client-onboarding",
    body: "The same engine that moves thousands of accounts during a transition, applied to every new client. Onboard in days, not weeks.",
  },
  {
    icon: "mic" as const,
    title: "Meeting Assistant",
    href: "/solutions/meeting-assistant",
    body: "Pre-meeting prep, in-meeting notes, post-meeting follow-ups. CRM updated in one click. Built for advisors who'd rather talk to clients than write up calls.",
  },
  {
    icon: "extract" as const,
    title: "Document Intelligence",
    href: "/solutions/document-intelligence",
    body: "Brokerage statements, tax docs, equity comp, extracted, organized, and ready for analysis. Goes from a stack of PDFs to insight in minutes.",
  },
];
---

<SectionShell bg="secondary" density="md" ariaLabelledby="beyond-heading">
  <div class="max-w-[820px]">
    <p class="text-eyebrow text-brand-green">And beyond</p>
    <h2 id="beyond-heading" class="mt-3 text-h2 text-text-primary">
      From moving the book to running the practice.
    </h2>
    <p class="mt-5 text-body-lg text-text-secondary">
      FastTrackr stays with you after the transition. The same AI engine that
      moved your book keeps your day-to-day operations running.
    </p>
  </div>

  <div class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-6">
    {
      cards.map((c) => (
        <a
          href={c.href}
          class="group flex flex-col bg-bg-primary border border-border-subtle rounded-[12px] p-8 md:p-10 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_4px_16px_rgba(15,23,42,0.06)]"
        >
          <div class="text-brand-green">
            <Icon name={c.icon} size={40} strokeWidth={1.75} />
          </div>
          <h3 class="mt-6 text-h3 text-text-primary">{c.title}</h3>
          <p class="mt-3 text-body text-text-secondary">{c.body}</p>
          <span class="mt-6 inline-flex items-center gap-1 text-[15px] font-medium text-text-primary group-hover:text-brand-green">
            Learn more
            <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
          </span>
        </a>
      ))
    }
  </div>
</SectionShell>
