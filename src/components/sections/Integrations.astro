---
import SectionShell from "../SectionShell.astro";

/*
 * §9 Integrations. Optional — can be hidden via CMS toggle.
 * Logos must be cleared before going live; until then this renders text
 * placeholders so we don't ship fake brand marks.
 */
const slots = [
  "Fidelity",
  "Schwab",
  "Salesforce",
  "Wealthbox",
  "Redtail",
  "DocuSign",
  "Orion",
  "eMoney",
];
---

<SectionShell bg="primary" density="sm" ariaLabelledby="integrations-heading">
  <div class="max-w-[820px]">
    <h3 id="integrations-heading" class="text-h3 text-text-primary">
      Works with the stack you already have.
    </h3>
    <p class="mt-3 text-body text-text-secondary">
      FastTrackr fits into your existing tools — no rip-and-replace. Custodial
      portals, CRMs, financial planning software, e-signature platforms. We
      extend what you have rather than ask you to start over.
    </p>
  </div>

  <ul class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-4">
    {
      slots.map((name) => (
        <li
          aria-hidden="true"
          class="flex items-center justify-center h-16 rounded-md border border-border-subtle bg-bg-primary text-body-sm font-semibold text-text-muted opacity-80"
        >{name}</li>
      ))
    }
  </ul>

  <p class="mt-6 text-body-sm text-text-muted">
    Some integrations are live; others are in active development. We're adding
    new ones every quarter.
  </p>
</SectionShell>
