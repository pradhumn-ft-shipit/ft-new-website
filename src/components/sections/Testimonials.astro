---
import SectionShell from "../SectionShell.astro";
import TestimonialCard from "../TestimonialCard.astro";

const featured = {
  quote:
    "This is the smoothest transition anyone in our circle has seen or heard about. It aligned with our workflow, and it just worked. We had planned for a month — we finished in two weeks. Amazing tool, very intuitive to use.",
  name: "Cana Wealth Advisors",
  role: "Customer",
};

const others = [
  {
    quote:
      "FastTrackr AI has been a game-changer for our practice. We're saving 10–15 hours weekly on meeting prep, CRM updates and follow-ups. Our clients love how quickly we follow up and that we never miss important details. It's made us more efficient and our service much better — honestly can't imagine running our firm without it.",
    name: "Christian von Stackelberg",
    role: "Partner",
    firm: "Radius Wealth Management",
  },
  {
    quote:
      "Using FastTrackr AI has been a key enhancement to my client meeting process. It's remarkably easy to use, the interface is intuitive, and the learning curve is minimal. Most importantly, the quality of the meeting notes is far better than what I would capture manually. The summaries are clear, detailed, and actionable, which has saved me valuable time and made sure nothing falls through the cracks. This tool has elevated both my documentation and the overall client experience.",
    name: "Gregg D. Jensen",
    role: "CCO and Head of Financial Planning",
    firm: "Pathway Partners",
  },
  {
    quote:
      "After evaluating multiple AI solutions for our practice, we chose FastTrackr for document processing. Its integrated platform has been invaluable — we quickly expanded to using the meeting assistant and data intake modules as well. The time savings are impressive, and even more importantly, the quality of our financial planning and client deliverables has improved significantly.",
    name: "Sukesh Pai",
    role: "Founder",
    firm: "Trillium Square Advisors",
  },
];
---

<SectionShell bg="secondary" ariaLabelledby="testimonials-heading">
  <div class="text-center max-w-[820px] mx-auto">
    <p class="text-eyebrow text-brand-green">In their words</p>
    <h2 id="testimonials-heading" class="mt-3 text-h2 text-text-primary">
      Top-performing advisors and firms use FastTrackr.
    </h2>
  </div>

  <div class="mt-14">
    <TestimonialCard
      variant="featured"
      quote={featured.quote}
      name={featured.name}
      role={featured.role}
    />
  </div>

  <div class="mt-8 grid grid-cols-1 lg:grid-cols-3 gap-6">
    {
      others.map((t) => (
        <TestimonialCard
          quote={t.quote}
          name={t.name}
          role={t.role}
          firm={t.firm}
        />
      ))
    }
  </div>
</SectionShell>
