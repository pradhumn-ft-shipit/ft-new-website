---
import SectionShell from "../SectionShell.astro";
import StatCard from "../StatCard.astro";
import FlywheelLoop from "../svg/FlywheelLoop.astro";

const stats = [
  { stat: "75%", label: "Faster", description: "Less admin. More books moved per quarter." },
  { stat: "Months → Weeks", label: "Cut down", description: "The 90-day timeline gets cut down dramatically." },
  { stat: "Fewer", label: "NIGOs", description: "Pre-validated, mapped forms. Cleaner submissions." },
  { stat: "Retained", label: "AUM", description: "Faster close means less attrition during the move." },
];
---

<SectionShell bg="secondary" ariaLabelledby="outcomes-heading">
  <div class="text-center max-w-[820px] mx-auto">
    <p class="text-eyebrow text-brand-green">Outcomes</p>
    <h2 id="outcomes-heading" class="mt-3 text-h2 text-text-primary">
      What changes when transitions stop being chaos.
    </h2>
  </div>

  <div class="mt-14 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    {
      stats.map((s) => (
        <StatCard stat={s.stat} label={s.label} description={s.description} />
      ))
    }
  </div>

  <p class="mt-16 max-w-[700px] mx-auto text-center text-body-lg italic text-text-secondary">
    And what doesn't show up in the numbers — calmer advisors, clients who
    barely notice the move, and ops teams that stop dreading next month.
  </p>

  <div class="mt-20">
    <FlywheelLoop />
  </div>
</SectionShell>
